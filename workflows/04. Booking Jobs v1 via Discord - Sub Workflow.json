    {
      "parameters": {
        "jsCode": "function getNowBrisbaneTimestamp() {\n  const now = new Date();\n  const parts = new Intl.DateTimeFormat(\"en-AU\", {\n    timeZone: \"Australia/Brisbane\",\n    year: \"numeric\",\n    month: \"2-digit\",\n    day: \"2-digit\",\n    hour: \"2-digit\",\n    minute: \"2-digit\",\n    second: \"2-digit\",\n    hour12: false,\n  }).formatToParts(now);\n\n  const map = Object.fromEntries(parts.map((p) => [p.type, p.value]));\n  return `${map.day}/${map.month}/${map.year} ${map.hour}:${map.minute}:${map.second}`;\n}\n\nreturn items.map((item) => {\n  let parsed = {};\n  try {\n    parsed = JSON.parse(item.json.output || \"{}\");\n  } catch (err) {\n    throw new Error(\n      `Failed to parse AI output JSON. output snippet: ${(item.json.output || \"\").slice(0, 200)}`\n    );\n  }\n\n  // ✅ csrName comes from AI output's authorName (since input only has \"output\")\n  const csrName = (parsed.authorName || \"\").toString().trim();\n\n  const howDidYouHear = (parsed.howDidYouHearAboutUs || \"\").toString().trim() || \"Google\";\n\n  const manJobNum = Number(parsed.manJob);\n  const manJob = Number.isFinite(manJobNum) && manJobNum > 0 ? manJobNum : 1;\n\n  const jobStart = (parsed.jobStart || \"\").toString().trim();\n  const jobEnd = ((parsed.jobEnd || \"\").toString().trim()) || jobStart;\n\n  const mobile = (parsed.mobileNumber || \"\").toString().replace(/\\s+/g, \"\").trim();\n\n  return {\n    json: {\n      id: (parsed.id || \"\").toString(),\n      channelId: (parsed.channelId || \"\").toString(),\n      authorId: (parsed.authorId || \"\").toString(),\n\n      // ✅ only csrName (authorName removed)\n      csrName,\n\n      timestamp: getNowBrisbaneTimestamp(),\n\n      customerFirstName: (parsed.customerFirstName || \"\").toString(),\n      customerLastName: (parsed.customerLastName || \"\").toString(),\n      customerJobTitle: (parsed.customerJobTitle || \"\").toString(),\n\n      emailAddress: (parsed.emailAddress || \"\").toString(),\n\n      streetAddress: (parsed.streetAddress || \"\").toString(),\n      streetAddressDescription: (parsed.streetAddressDescription || \"\").toString(),\n      suburb: (parsed.suburb || \"\").toString(),\n      postalCode: (parsed.postalCode || \"\").toString(),\n\n      mobileNumber: mobile,\n      phoneNumber: (parsed.phoneNumber || \"\").toString(),\n\n      howDidYouHearAboutUs: howDidYouHear,\n\n      isDhWsNsEmporium: parsed.isDhWsNsEmporium ?? false,\n\n      jobServices: (parsed.jobServices || \"\").toString(),\n      jobStart,\n      jobEnd,\n      jobType: (parsed.jobType || \"\").toString(),\n\n      jobDescription: (parsed.jobDescription || \"\").toString(),\n      dspNotes: (parsed.dspNotes || \"\").toString(),\n\n      estTimeHours: Number(parsed.estTimeHours) || 0,\n      estPrice: Number(parsed.estPrice) || 0,\n      manJob,\n\n      // ✅ technicianName from AI\n      technicianName: (parsed.technicianName || \"\").toString(),\n\n      recap: (parsed.recap || \"\").toString(),\n\n      isCreated: true,\n    },\n  };\n});"
      },
