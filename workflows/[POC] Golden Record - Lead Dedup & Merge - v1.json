        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"source_system\": $json.source, \"raw_full_name\": $json.raw_name, \"normalized_full_name\": $json.normalized_full_name, \"first_name\": $json.first_name, \"last_name\": $json.last_name, \"phone_primary\": $json.phone, \"email_primary\": $json.email, \"raw_address\": $json.address, \"deceased_flag\": $json.deceased_flag, \"review_status\": $json.review_status } }}",
        "options": {
          "response": {
