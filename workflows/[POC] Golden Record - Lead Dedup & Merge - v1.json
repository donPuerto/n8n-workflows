      ]
    },
    {
      "parameters": {},
      "id": "ab22c002-2222-4bbb-cccc-cascade0002cd",
      "name": "Merge: All Sources",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        1104,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\nlet idx = 0;\nfor (const item of items) {\n  const d = item.json;\n  const src = d.source || 'unknown';\n  const rawName = d.raw_name || d.name || '';\n  const deceasedFlag = /(DECEASED|DECSD|DEC'D)/i.test(rawName);\n  let firstName = '', lastName = '';\n  const cleanName = rawName.replace(/\\s*\\(DECEASED\\)|\\s*\\(DECSD\\)|\\s*\\(DEC'D\\)/gi, '').trim();\n  if (cleanName.includes(',')) {\n    const parts = cleanName.split(',').map(p => p.trim());\n    lastName = parts[0].charAt(0).toUpperCase() + parts[0].slice(1).toLowerCase();\n    const fnParts = (parts[1] || '').trim().split(/\\s+/);\n    firstName = fnParts.map(p => p.charAt(0).toUpperCase() + p.slice(1).toLowerCase()).join(' ');\n  } else {\n    const parts = cleanName.trim().split(/\\s+/);\n    firstName = parts[0] ? parts[0].charAt(0).toUpperCase() + parts[0].slice(1).toLowerCase() : '';\n    lastName = parts.slice(1).map(p => p.charAt(0).toUpperCase() + p.slice(1).toLowerCase()).join(' ');\n  }\n  const normalizedFullName = [firstName, lastName].filter(Boolean).join(' ');\n  const rawPhone = (d.phone || '').replace(/\\D/g, '');\n  const phone = rawPhone.length >= 7 ? rawPhone.slice(-7, -4) + '-' + rawPhone.slice(-4) : rawPhone;\n  const sourcePriority = src === 'county_csv' ? 3 : (src === 'researcher' ? 2 : 1);\n  results.push({ json: {\n    record_id: 'REC-' + String(++idx).padStart(3, '0'),\n    source: src, source_priority: sourcePriority,\n    raw_name: rawName, normalized_full_name: normalizedFullName,\n    first_name: firstName, last_name: lastName,\n    phone: phone, email: (d.email || '').toLowerCase().trim(),\n    address: (d.address || '').trim(),\n    deceased_flag: deceasedFlag,\n    review_status: deceasedFlag ? 'needs_review' : 'pending',\n  }});\n}\nreturn results;"
      },
      "id": "d2fc5125-1590-4ad9-85c6-e604fcfa340c",
      "name": "Code: Normalize & Flag",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1296,
        304
      ]
    },
