      "id": "4cdb363a-69e6-4d8d-80db-587ada145c8d",
      "name": "Code: Wait for Clay",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1744,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "function jaroWinkler(s1, s2) {\n  if (!s1 || !s2) return 0;\n  s1 = s1.toLowerCase(); s2 = s2.toLowerCase();\n  if (s1 === s2) return 1;\n  const len1 = s1.length, len2 = s2.length;\n  const matchDist = Math.max(Math.floor(Math.max(len1, len2) / 2) - 1, 0);\n  const s1m = new Array(len1).fill(false), s2m = new Array(len2).fill(false);\n  let matches = 0, transpositions = 0;\n  for (let i = 0; i < len1; i++) {\n    const start = Math.max(0, i - matchDist), end = Math.min(i + matchDist + 1, len2);\n    for (let j = start; j < end; j++) {\n      if (s2m[j] || s1[i] !== s2[j]) continue;\n      s1m[i] = s2m[j] = true; matches++; break;\n    }\n  }\n  if (matches === 0) return 0;\n  let k = 0;\n  for (let i = 0; i < len1; i++) {\n    if (!s1m[i]) continue;\n    while (!s2m[k]) k++;\n    if (s1[i] !== s2[k]) transpositions++;\n    k++;\n  }\n  const jaro = (matches/len1 + matches/len2 + (matches - transpositions/2)/matches) / 3;\n  let prefix = 0;\n  for (let i = 0; i < Math.min(4, Math.min(len1, len2)); i++) { if (s1[i] === s2[i]) prefix++; else break; }\n  return jaro + prefix * 0.1 * (1 - jaro);\n}\nconst crmRows = $('Google Sheets: Read CRM Mock').all();\nconst normalizedItems = $('Code: Normalize & Flag').all();\nconst results = [];\nfor (const item of normalizedItems) {\n  const d = item.json;\n  let bestScore = 0, bestMatch = null;\n  for (const crmItem of crmRows) {\n    const crm = crmItem.json;\n    const inPhone = (d.phone || '').replace(/\\D/g,'');\n    const crmPhone = (crm.phone || '').replace(/\\D/g,'');\n    let phoneScore = 0;\n    if (inPhone && crmPhone) { if (inPhone === crmPhone) phoneScore = 1.0; else if (inPhone.slice(-7) === crmPhone.slice(-7)) phoneScore = 0.8; }\n    const inEmail = (d.email || '').toLowerCase().trim();\n    const crmEmail = (crm.email || '').toLowerCase().trim();\n    let emailScore = 0;\n    if (inEmail && crmEmail) { if (inEmail === crmEmail) emailScore = 1.0; else { const iD = inEmail.split('@')[1]; const cD = crmEmail.split('@')[1]; if (iD && cD && iD === cD) emailScore = 0.3; } }\n    const nameScore = jaroWinkler(d.normalized_full_name || '', crm.full_name || '');\n    const addrScore = jaroWinkler(d.address || '', crm.address || '');\n    const total = phoneScore*0.4 + emailScore*0.3 + nameScore*0.2 + addrScore*0.1;\n    if (total > bestScore) { bestScore = total; bestMatch = crm; }\n  }\n  results.push({ json: { ...d,\n    match_score: Math.round(bestScore * 100) / 100,\n    best_match_id: bestMatch ? bestMatch.contact_id : null,\n    best_match_name: bestMatch ? bestMatch.full_name : null,\n    best_match_phone: bestMatch ? bestMatch.phone : null,\n    best_match_email: bestMatch ? bestMatch.email : null,\n    best_match_address: bestMatch ? bestMatch.address : null,\n  }});\n}\nreturn results;"
      },
      "id": "956b915b-1be2-49ec-9e5d-89562b8dfa11",
      "name": "Code: Fuzzy Match Scoring",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1952,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(function(item) {\n  return {\n    json: Object.assign({}, item.json, {\n      route: item.json.match_score >= 0.7 ? 'merge' : (item.json.match_score >= 0.5 ? 'review' : 'create_new')\n    })\n  };\n});"
      },
      "id": "52df5c13-eafe-4aaa-b8c1-d3cd148e794b",
      "name": "Code: Route by Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2160,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const mergeItems = $input.all().filter(function(item) { return item.json.route === 'merge'; });\nif (mergeItems.length === 0) return [];\nconst results = [];\nfor (var i = 0; i < mergeItems.length; i++) {\n  var d = mergeItems[i].json;\n  var conflictFlag = !!(d.phone && d.best_match_phone && d.phone !== d.best_match_phone);\n  results.push({ json: {\n    golden_record_id: 'GR-' + d.best_match_id,\n    source_systems: d.source,\n    raw_full_name: d.raw_name,\n    normalized_full_name: d.normalized_full_name,\n    first_name: d.first_name,\n    last_name: d.last_name,\n    phone_primary: d.best_match_phone || d.phone,\n    phone_secondary: conflictFlag ? d.phone : '',\n    email_primary: d.email || d.best_match_email || '',\n    normalized_address: d.address || d.best_match_address || '',\n    est_property_value: d.est_property_value || '',\n    deceased_flag: d.deceased_flag === true,\n    source_priority: d.source_priority,\n    match_score: d.match_score,\n    conflict_flag: conflictFlag,\n    review_status: d.deceased_flag === true ? 'needs_review' : 'merged',\n    last_updated_at: new Date().toISOString(),\n  }});\n}\nreturn results;"
      },
